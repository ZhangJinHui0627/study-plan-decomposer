<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/about_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_app_gradient">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:titleTextColor="#1F1F1F"
        app:title="关于"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="#1F1F1F" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <FrameLayout
                android:id="@+id/fl_avatar"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:clipChildren="false"
                android:layout_marginBottom="16dp"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true">

                <com.example.studyplan.AvatarFrameView
                    android:id="@+id/v_avatar_bg"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:layout_gravity="center" />
                <ImageView
                    android:id="@+id/iv_avatar"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:scaleType="centerCrop" />
                <TextView
                    android:id="@+id/tv_avatar_text"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:gravity="center"
                    android:text="学"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <TextView
                android:id="@+id/tv_app_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="学习计划拆解"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1F1F1F" />

            <TextView
                android:id="@+id/tv_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                    android:text="alpha-2"
                android:textSize="14sp"
                android:textColor="#5F6368"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="32dp" />

            <!-- 合二为一的牛奶磨砂玻璃卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card"
                android:padding="20dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="关于应用"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1F1F1F"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="学习计划智能拆解与提醒 App\n\n帮助大学生将自然语言学习计划拆解为结构化任务，支持提醒与进度管理。"
                    android:textSize="14sp"
                    android:textColor="#5F6368"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="16dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#E0E0E0"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="开发者：张锦慧"
                    android:textSize="14sp"
                    android:textColor="#1F1F1F"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="协作者：吴思彤"
                    android:textSize="14sp"
                    android:textColor="#1F1F1F"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tv_dev_version"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="版本：alpha-2"
                    android:textSize="14sp"
                    android:textColor="#5F6368"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="技术栈：Android 原生 Java + SQLite"
                    android:textSize="14sp"
                    android:textColor="#5F6368" />
            </LinearLayout>

            <!-- 版本历史可折叠卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card"
                android:padding="6dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:id="@+id/item_version_history"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_about"
                        app:tint="#1F1F1F" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:text="版本历史"
                        android:textSize="15sp"
                        android:textColor="#1F1F1F" />

                    <ImageView
                        android:id="@+id/iv_arrow_version"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="#5F6368" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_version_history_details"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="54dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="16dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="alpha-1：首个功能与界面重构升级版本。支持条件式高级计时专注与转屏状态保护、拖拽重排与三层状态智能重载、系统日历双向安全同步与防泄露清理；已累计修补 50 余项涉及开机广播监听、时间越界过滤、时区动态对齐、多设备硬编字符集兼容等底层稳定性缺陷；全新升级牛奶玻璃悬浮卡片、防遮挡滚动面板及无重影无残留弹窗交互。"
                        android:textSize="14sp"
                        android:textColor="#5F6368"
                        android:lineSpacingExtra="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="alpha-2：统一任务卡片状态、计时与弹窗交互样式；修复无时长任务秒完成、无绑定计时跑马灯缺失等问题；新增统计页状态概览与专注建议，并优化学科词库及清空任务弹窗布局。"
                        android:textSize="14sp"
                        android:textColor="#5F6368"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
